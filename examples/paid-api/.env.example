# Address that receives x402 payments (your EVM address on Base Sepolia)
SELLER_PAY_TO=0xYourBaseSepoliaAddress

# Price per call, in USD
SELLER_PRICE_USD=0.01

# Public origin (set when behind a proxy so the x402 resource URL is correct)
# PUBLIC_BASE_URL=https://your-deployment.example.com

# x402 facilitator (default settles Base Sepolia via the public facilitator)
FACILITATOR_URL=https://x402.org/facilitator

# Port
PORT=4021
