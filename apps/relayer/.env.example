# Treasury key that settles x402 payments on callers' behalf (EVM, 0x + 64 hex)
PRISM_TREASURY_EVM_KEY=0xyourtreasurykey

# Settlement network: base or base-sepolia
PRISM_RELAYER_NETWORK=base-sepolia

# Shared secret required on admin/settle endpoints (recommended in production)
PRISM_ADMIN_SECRET=change-me

# Optional fiat on-ramp checkout base URL (a provider's hosted widget)
# PRISM_ONRAMP_URL=https://onramp.example.com/checkout

# Port
PORT=3100
