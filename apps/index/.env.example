# Prism Index configuration. Copy to `.env` and adjust as needed.
# Everything here is OPTIONAL — with no env set, the app runs on an in-memory
# store, seeds demo listings, and serves on port 8787.

# Postgres connection string. When set, the Drizzle/Postgres store is used
# instead of the in-memory store (lazily imported). Leave unset for local dev.
# DATABASE_URL=postgres://user:pass@host:5432/prism_index

# When set, POST /v1/listings requires header `x-prism-submit-key` to match.
# Leave unset to allow open submissions in development.
# PRISM_SUBMIT_KEY=change-me-submit

# When set, POST /v1/admin/run-checks requires header `x-prism-admin-key` to
# match. Leave unset to allow triggering checks in development.
# PRISM_ADMIN_KEY=change-me-admin

# HTTP port for the Node server (server.ts). Defaults to 8787.
# PORT=8787

# Optional log level for @prism/core's logger: debug | info | warn | error
# PRISM_LOG_LEVEL=info
