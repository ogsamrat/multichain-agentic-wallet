{
  "name": "@prism/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing the Prism wallet to AI agents over stdio.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "prism-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "manifest.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@prism/chains": "*",
    "@prism/core": "*",
    "@prism/protocol": "*",
    "@prism/sdk": "*",
    "@prism/wallet": "*"
  }
}
