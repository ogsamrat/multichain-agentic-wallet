{
  "name": "@prism/relayer",
  "version": "0.1.0",
  "description": "Optional managed treasury/relayer: delegated x402 settlement, fiat on-ramp, and non-custodial withdrawal.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/server.js",
    "dev": "node --watch dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@prism/core": "*",
    "@prism/protocol": "*",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "hono": "^4.12.26",
    "viem": "^2.21.0",
    "zod": "^3.25.76"
  }
}
